# Caddyfile for Tax Document Service
# Simple HTTP-only configuration for BE and NL tax files
{
	# Global settings
	# auto_https off
	admin off
}

# BE tax documents service (HTTP + HTTPS)
be.tax.local:2015, https://be.tax.local {
	log {
		output file out/log/caddy/be-access.log
		format json
		level DEBUG
	}

	@dated_files {
		path_regexp dated_pattern ^/(20[0-9]{2})(0[1-9]|1[0-2])_(.*)$
	}

	handle @dated_files {
		root * {the-date-root-path}
		rewrite * /{http.regexp.dated_pattern.1}/{http.regexp.dated_pattern.2}/{http.regexp.dated_pattern.1}{http.regexp.dated_pattern.2}_{http.regexp.dated_pattern.3}
		file_server
	}

	handle {
		root * {the-default-root-path}
		file_server
	}

	header {
		-Server
		X-Content-Type-Options "nosniff"
		Referrer-Policy "same-origin"
		X-Frame-Options "SAMEORIGIN"
	}
}

# NL tax documents service (HTTP + HTTPS)
nl.tax.local:2015, https://nl.tax.local {
	log {
		output file out/log/caddy/nl-access.log
		format json
		level DEBUG
	}

	@dated_files {
		path_regexp dated_pattern ^/(20[0-9]{2})(0[1-9]|1[0-2])_(.*)$
	}

	handle @dated_files {
		root * {the-date-root-path}
		rewrite * /{http.regexp.dated_pattern.1}/{http.regexp.dated_pattern.2}/{http.regexp.dated_pattern.1}{http.regexp.dated_pattern.2}_{http.regexp.dated_pattern.3}
		file_server
	}

	handle {
		root * {the-default-root-path}
		file_server
	}

	header {
		-Server
		X-Content-Type-Options "nosniff"
		Referrer-Policy "same-origin"
		X-Frame-Options "SAMEORIGIN"
	}
}
